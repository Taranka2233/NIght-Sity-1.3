rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function chat(chatId) {
      return get(/databases/$(database)/documents/chats/$(chatId)).data;
    }

    function isChatMember(chatId) {
      return signedIn() && request.auth.uid in chat(chatId).members;
    }

    function isChatAdmin(chatId) {
      return isChatMember(chatId) && (
        chat(chatId).get('owner', '') == request.auth.uid ||
        request.auth.uid in chat(chatId).get('admins', [])
      );
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.keys().hasOnly([
          'uid', 'handle', 'name', 'nameLower', 'status', 'createdAt'
        ]);
      allow update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.handle == resource.data.handle
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name', 'nameLower', 'status', 'avatar', 'pubKey', 'online', 'lastActive',
          'email', 'phone', 'fcmToken'
        ])
        && !request.resource.data.keys().hasAny(['email', 'phone', 'fcmToken']);
      allow delete: if false;

      match /contacts/{contactId} {
        allow read, create, update, delete: if signedIn() && request.auth.uid == uid;
      }

      match /private/{document} {
        allow read, create, update, delete: if signedIn() && request.auth.uid == uid;
      }
    }

    match /handles/{handle} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid', 'createdAt']);
      allow update, delete: if false;
    }

    match /chats/{chatId} {
      function member() {
        return signedIn() && request.auth.uid in resource.data.members;
      }

      function invited() {
        return signedIn()
          && resource.data.get('pending', []) is list
          && request.auth.uid in resource.data.get('pending', []);
      }

      function admin() {
        return member() && (
          resource.data.get('owner', '') == request.auth.uid ||
          request.auth.uid in resource.data.get('admins', [])
        );
      }

      function validCreate() {
        return request.resource.data.members is list
          && request.resource.data.members.size() >= 1
          && request.resource.data.members.size() <= 100
          && request.auth.uid in request.resource.data.members
          && request.resource.data.get('pending', []) is list
          && request.resource.data.get('pending', []).size() <= 100
          && !(request.auth.uid in request.resource.data.get('pending', []))
          && (
            request.resource.data.get('owner', '') == '' ||
            request.resource.data.get('owner', '') in request.resource.data.members
          )
          && request.resource.data.members.hasAll(request.resource.data.get('admins', []))
          && (
            request.resource.data.get('createdBy', '') == request.auth.uid ||
            request.resource.data.get('owner', '') == request.auth.uid
          )
          && request.resource.data.keys().hasOnly([
            'members', 'pending', 'createdBy', 'owner', 'admins', 'name', 'gtype', 'avatar',
            'memberNames', 'pendingNames', 'isGroup', 'isChannel', 'updatedAt', 'lastText', 'lastFrom',
            'unread', 'read', 'typing', 'pinnedId'
          ]);
      }

      function activityUpdate() {
        return member()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'updatedAt', 'lastText', 'lastFrom', 'unread', 'read', 'typing'
          ])
          && request.resource.data.get('members', []) == resource.data.members
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastFrom']) ||
            request.resource.data.lastFrom == request.auth.uid
          );
      }

      function adminUpdate() {
        return admin()
          && request.resource.data.get('owner', '') == resource.data.get('owner', '')
          && resource.data.members.hasAll(request.resource.data.members)
          && request.resource.data.get('owner', '') in request.resource.data.members
          && request.resource.data.members.hasAll(request.resource.data.get('admins', []))
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'members', 'pending', 'memberNames', 'pendingNames', 'admins', 'name', 'gtype', 'avatar', 'pinnedId',
            'updatedAt', 'lastText', 'lastFrom', 'unread', 'read', 'typing'
          ]);
      }

      function leaveUpdate() {
        return member()
          && resource.data.get('owner', '') != request.auth.uid
          && !(request.auth.uid in request.resource.data.members)
          && request.resource.data.members.size() == resource.data.members.size() - 1
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberNames']);
      }

      function inviteDecision() {
        return invited()
          && request.resource.data.get('pending', []) is list
          && resource.data.pending.hasAll(request.resource.data.pending)
          && request.resource.data.pending.size() == resource.data.pending.size() - 1
          && !(request.auth.uid in request.resource.data.pending)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'members', 'pending', 'memberNames', 'pendingNames'
          ])
          && request.resource.data.get('memberNames', {}).diff(resource.data.get('memberNames', {})).affectedKeys().hasOnly([request.auth.uid])
          && request.resource.data.get('pendingNames', {}).diff(resource.data.get('pendingNames', {})).affectedKeys().hasOnly([request.auth.uid])
          && (
            (
              request.resource.data.members.hasAll(resource.data.members)
              && request.resource.data.members.size() == resource.data.members.size() + 1
              && request.auth.uid in request.resource.data.members
            ) ||
            request.resource.data.members == resource.data.members
          );
      }

      allow read: if member() || invited();
      allow create: if signedIn() && validCreate();
      allow update: if activityUpdate() || adminUpdate() || leaveUpdate() || inviteDecision();
      allow delete: if false;

      match /messages/{messageId} {
        function messageFields() {
          return request.resource.data.keys().hasOnly([
            'from', 'type', 'ts', 'text', 'imgSrc', 'audioSrc', 'vidSrc', 'stickerSrc',
            'fileData', 'fileName', 'duration', 'caption', 'ice', 'iceData', 'ghost',
            'ghostSec', 'ghostAt', 'replyTo', 'replyText', 'replyFrom', 'fwdFrom',
            'e2e', 'encText', 'encIv', 'gkeys', 'reactions', 'edited',
            'enc_imgSrc', 'enc_imgSrc_iv', 'enc_audioSrc', 'enc_audioSrc_iv',
            'enc_vidSrc', 'enc_vidSrc_iv', 'enc_fileData', 'enc_fileData_iv',
            'enc_fileName', 'enc_fileName_iv', 'enc_caption', 'enc_caption_iv',
            'enc_replyText', 'enc_replyText_iv', 'enc_replyFrom', 'enc_replyFrom_iv',
            'enc_fwdFrom', 'enc_fwdFrom_iv', 'enc_iceData', 'enc_iceData_iv',
            'enc_stickerSrc', 'enc_stickerSrc_iv'
          ]);
        }

        function encryptedWhenRequired() {
          return chat(chatId).get('isChannel', false) == true ||
            (
              request.resource.data.get('e2e', false) == true
              && request.resource.data.get('text', '🔒') == '🔒'
              && !request.resource.data.keys().hasAny([
                'imgSrc', 'audioSrc', 'vidSrc', 'fileData', 'fileName', 'caption',
                'replyText', 'replyFrom', 'fwdFrom', 'iceData', 'stickerSrc'
              ])
            );
        }

        allow read: if isChatMember(chatId);
        allow create: if isChatMember(chatId)
          && request.resource.data.from == request.auth.uid
          && request.resource.data.type is string
          && messageFields()
          && encryptedWhenRequired();
        allow update: if isChatMember(chatId) && (
          (
            resource.data.from == request.auth.uid
            && request.resource.data.from == resource.data.from
            && (
              (
                chat(chatId).get('isChannel', false) == true
                && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'edited'])
              ) ||
              (
                resource.data.get('e2e', false) == true
                && request.resource.data.get('text', '🔒') == resource.data.get('text', '🔒')
                && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['encText', 'encIv', 'gkeys', 'edited'])
              )
            )
          ) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
        );
        allow delete: if isChatMember(chatId) && (
          resource.data.from == request.auth.uid || isChatAdmin(chatId)
        );
      }
    }

    match /calls/{callId} {
      function participant() {
        return signedIn() && request.auth.uid in [resource.data.from, resource.data.to];
      }

      allow read: if participant();
      allow create: if signedIn()
        && request.resource.data.from == request.auth.uid
        && request.resource.data.to is string
        && request.resource.data.to != request.auth.uid
        && request.resource.data.chatId is string
        && request.resource.data.status == 'ringing'
        && request.auth.uid in chat(request.resource.data.chatId).members
        && request.resource.data.to in chat(request.resource.data.chatId).members
        && request.resource.data.keys().hasOnly([
          'from', 'to', 'chatId', 'fromName', 'kind', 'offer', 'answer', 'status',
          'createdAt', 'groupCall', 'roomId', 'groupName'
        ]);
      allow update: if participant()
        && request.resource.data.from == resource.data.from
        && request.resource.data.to == resource.data.to
        && request.resource.data.chatId == resource.data.chatId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['answer', 'status'])
        && request.resource.data.status in ['ringing', 'accepted', 'declined', 'ended'];
      allow delete: if participant();

      match /{side}/{candidateId} {
        allow read, create: if signedIn()
          && request.auth.uid in [
            get(/databases/$(database)/documents/calls/$(callId)).data.from,
            get(/databases/$(database)/documents/calls/$(callId)).data.to
          ];
        allow update, delete: if false;
      }
    }

    match /groupcalls/{roomId} {
      function roomMember() {
        return isChatMember(roomId);
      }

      allow read: if roomMember();
      allow create: if roomMember()
        && request.resource.data.keys().hasOnly(['active', 'kind', 'startedBy', 'startedAt', 'groupId'])
        && request.resource.data.startedBy == request.auth.uid
        && request.resource.data.groupId == roomId;
      allow update: if roomMember()
        && request.resource.data.startedBy == resource.data.startedBy
        && request.resource.data.startedAt == resource.data.startedAt
        && request.resource.data.groupId == resource.data.groupId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['active', 'kind']);
      allow delete: if false;

      match /members/{memberUid} {
        allow read: if roomMember();
        allow create, update: if roomMember()
          && request.auth.uid == memberUid
          && request.resource.data.uid == memberUid
          && request.resource.data.keys().hasOnly(['uid', 'name', 'ts']);
        allow delete: if roomMember() && request.auth.uid == memberUid;
      }

      match /pairs/{pairId} {
        allow read: if roomMember();
        allow create: if roomMember()
          && request.resource.data.participants is list
          && request.resource.data.participants.size() == 2
          && request.resource.data.participants[0] != request.resource.data.participants[1]
          && request.auth.uid in request.resource.data.participants
          && request.resource.data.participants[0] in chat(roomId).members
          && request.resource.data.participants[1] in chat(roomId).members
          && request.resource.data.keys().hasOnly(['participants', 'offer', 'answer']);
        allow update: if roomMember()
          && request.auth.uid in resource.data.participants
          && request.resource.data.participants == resource.data.participants
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['offer', 'answer']);
        allow delete: if false;

        match /{side}/{candidateId} {
          allow read, create: if roomMember()
            && request.auth.uid in get(/databases/$(database)/documents/groupcalls/$(roomId)/pairs/$(pairId)).data.participants;
          allow update, delete: if false;
        }
      }
    }
  }
}
